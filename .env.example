# ─────────────────────────────────────────────────────────────────────────────
# BetterDB RAG Demo — Environment Template
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── BetterDB Cloud ────────────────────────────────────────────────────────────
BETTERDB_URL=https://betterdb-test1.app.betterdb.com
BETTERDB_TOKEN=your_betterdb_token_here

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Redis — choose ONE option ─────────────────────────────────────────────────

# OPTION A: Upstash (cloud Redis, zero infra, already monitored by BetterDB)
# Get password: Upstash Dashboard → your DB → TCP tab → uncheck "Read-Only Token" → copy
# Note: double-s in rediss:// enables TLS (required for Upstash)
REDIS_URL=rediss://default:your_upstash_token@quiet-flea-79665.upstash.io:6379

# OPTION B: Local Valkey via Docker (better for slowlog demo, 0.1ms RTT)
# Run first: docker-compose up -d
# Then uncomment the line below and comment out OPTION A above
# REDIS_URL=redis://localhost:6379

# ── RAG App — optional overrides (defaults shown) ────────────────────────────
# OPENAI_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small
# CACHE_THRESHOLD=0.85
# RATE_LIMIT_MINUTE=10
# RATE_LIMIT_HOUR=100
# CHUNK_SIZE=500
# CHUNK_OVERLAP=50

# ── Upstash REST (optional, not used by RAG app — for reference only) ─────────
# UPSTASH_REDIS_REST_URL=https://quiet-flea-79665.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_rest_token_here
